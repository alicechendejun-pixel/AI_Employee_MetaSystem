# FinMediaCrew · 环境变量模板
# 拷贝为 .env 后填入真实值。.env 不要提交到 git。

# ── LLM Keys ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FINMEDIA_LLM_MODEL=gpt-4o-mini       # 或 gpt-5 / claude-4-7-sonnet 等

# ── 金融数据 ──
FMP_API_KEY=                          # https://financialmodelingprep.com/developer
STOCKTWITS_API_KEY=                   # 可选
ADANOS_API_KEY=                       # FinRobot 用，可选

# ── 上游 SKILL 路径 (覆盖默认) ──
FINROBOT_ROOT=G:\我的云端硬盘\09-AI员工系统\03_Wealth_Trading_搞钱与交易\FinRobot
TRADINGAGENTS_ROOT=G:\我的云端硬盘\09-AI员工系统\03_Wealth_Trading_搞钱与交易\TradingAgents
AUTOHEDGE_ROOT=G:\我的云端硬盘\09-AI员工系统\03_Wealth_Trading_搞钱与交易\AutoHedge

# ── 分发 ──
FEISHU_WEBHOOK_URL=                   # 飞书自定义机器人 webhook
FEISHU_GROUP_ID=oc_da1ba12165aa160e5b24b68ffaaa8d0d
WECHAT_APP_ID=                        # 公众号 (可选 OAuth)
WECHAT_APP_SECRET=
XIAOHONGSHU_USER_ID=                  # 半自动用，无官方 API

# ── 控制 ──
TRADINGAGENTS_DEBATE_ROUNDS=2         # 1=shallow / 2=medium / 3=deep
FINMEDIA_DEFAULT_TICKER=NVDA          # 默认 ticker
